{
  "version": "3.1.0",
  "exclude": [
    ".github/"
  ],
  "fmt": {
    "exclude": ["CHANGELOG.md"]
  },
  "tasks": {
    "dev": "deno run --allow-all src/index.ts",
    "test": "deno test --allow-all",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "compile": "deno compile --include vendor --no-check --allow-net --allow-read --allow-write --allow-run --allow-env --allow-sys --output tesseract-server src/index.ts"
  },
  "imports": {
    "express": "npm:express@^5.0.0",
    "@cloudnative/health-connect": "npm:@cloudnative/health-connect@^2.1.0",
    "multer": "npm:multer@^2.0.0",
    "yargs": "npm:yargs@^17.7.2",
    "generic-pool": "npm:generic-pool@^3.9.0",
    "decoders": "npm:decoders@^1.25.5",
    "monaco-editor": "npm:monaco-editor@^0.49.0",
    "event-loop-lag": "npm:event-loop-lag@^1.4.0",
    "remark": "npm:remark@^13.0.0",
    "unist-util-select": "npm:unist-util-select@^3.0.4",
    "@std/assert": "jsr:@std/assert@^1",
    "@logtape/logtape": "jsr:@logtape/logtape@^0.12"
  },
  "compilerOptions": {
    "strict": true
  }
}
